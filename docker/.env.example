# Copy to .env and edit — `cp .env.example .env`

# --- Meter ---
# Leave blank to pick your meter in the web GUI (Scan button). Set to force a MAC.
METER_MAC=
METER_CH=6
POLL_SECS=1200

# --- MQTT broker (your Mosquitto / Home Assistant broker) ---
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
